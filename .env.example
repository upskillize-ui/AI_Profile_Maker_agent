# ═══════════════════════════════════════════════
# UPSKILLIZE PROFILE AGENT v3 — ENVIRONMENT
# ═══════════════════════════════════════════════
#
# ⚠️  SECURITY RULES:
#   1. Copy this file to .env and fill in YOUR values
#   2. NEVER commit .env to git
#   3. NEVER share .env in zip files
#   4. NEVER put real credentials in this .env.example file
#   5. The .gitignore blocks .env — do NOT remove that rule
#
# ═══════════════════════════════════════════════

# Database — your MySQL connection
# Replace with YOUR Aiven/local database URL
DATABASE_URL=mysql+pymysql://username:password@hostname:port/database_name

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT Secret — MUST match your Node.js LMS backend JWT_SECRET
# Generate a strong random string: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_YOUR_ACTUAL_JWT_SECRET

# App
BASE_URL=https://upskillize.com
PROFILE_URL_PREFIX=https://upskillize.com/profile
DEBUG=false

# Email Notifications
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@upskillize.com
MAIL_PASSWORD=REPLACE_WITH_APP_PASSWORD
MAIL_FROM=noreply@upskillize.com

# ═══════════════════════════════════════════════
# NO API KEYS NEEDED — Profile generation is 100% rule-based
# ═══════════════════════════════════════════════
